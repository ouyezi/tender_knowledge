# Copy to .env and adjust if needed.
DATABASE_URL=postgresql+psycopg://tender:tender@127.0.0.1:5433/tender_knowledge

# LLM — switch provider without code changes.
# Supported presets: qwen (default) | openai
# For custom endpoints set LLM_PROVIDER=custom and override base_url/model.
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_MAX_CHUNK_CHARS=8000
LLM_REQUEST_TIMEOUT_SEC=60
BLUEPRINT_GENERATE_TIMEOUT_SEC=120
BLUEPRINT_GENERATE_MAX_TOKENS=16384
BLUEPRINT_GENERATE_MODEL=qwen3.6-flash
BLUEPRINT_SUGGEST_MODEL=qwen3.6-flash
BLUEPRINT_SUGGEST_TIMEOUT_SEC=120
BLUEPRINT_SUGGEST_MAX_TOKENS=8192
BLUEPRINT_SUGGEST_MAX_BLUEPRINTS=5
BLUEPRINT_SUGGEST_REQUIREMENT_MAX=2000
BLUEPRINT_SEARCH_PARSE_MODEL=qwen3.6-flash
BLUEPRINT_SEARCH_PARSE_TIMEOUT_SEC=30
BLUEPRINT_SEARCH_PARSE_QUERY_MAX=500
BLUEPRINT_SEARCH_NAME_KEYWORD_WEIGHT=3.0
BLUEPRINT_SEARCH_BODY_KEYWORD_WEIGHT=1.0
BLUEPRINT_SEARCH_VECTOR_MIN_SIMILARITY=0.10
BLUEPRINT_SEARCH_EXACT_MATCH_BOOST=0.35
# Embedding — 百炼 OpenAI 兼容接口，默认复用 LLM_API_KEY / LLM_BASE_URL。
# 文档: https://help.aliyun.com/zh/model-studio/developer-reference/text-embedding-synchronous-api
# endpoint: POST https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
# 仅需单独配置 EMBEDDING_API_BASE / EMBEDDING_API_KEY 时填写下方两项。
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
KNOWLEDGE_VISION_MODEL=qwen-vl-max
KNOWLEDGE_VISION_TIMEOUT_SEC=60
KNOWLEDGE_VISION_MAX_IMAGES=20
KNOWLEDGE_INDEX_SUMMARY_MODEL=qwen3-max
KNOWLEDGE_INDEX_SUMMARY_TIMEOUT_SEC=30
CHUNK_SEARCH_PARSE_MODEL=qwen3.6-flash
CHUNK_SEARCH_PARSE_TIMEOUT_SEC=30
ENTRY_TREE_REFINE_MODEL=qwen-plus
ENTRY_TREE_REFINE_MAX_TOKENS=10000
ENTRY_TREE_REFINE_TIMEOUT_SEC=120
ENTRY_TREE_REFINE_BATCH_SIZE=400
CHUNK_SEARCH_PARSE_QUERY_MAX=500
CHUNK_SEARCH_TITLE_KEYWORD_WEIGHT=3.0
CHUNK_SEARCH_BODY_KEYWORD_WEIGHT=1.0
CHUNK_SEARCH_VECTOR_MIN_SIMILARITY=0.10
CHUNK_SEARCH_EXACT_MATCH_BOOST=0.35

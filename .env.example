# Copy to .env and adjust if needed.
DATABASE_URL=postgresql+psycopg://tender:tender@127.0.0.1:5433/tender_knowledge

# LLM — switch provider without code changes.
# Supported presets: qwen (default) | openai
# For custom endpoints set LLM_PROVIDER=custom and override base_url/model.
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_MAX_CHUNK_CHARS=8000
LLM_REQUEST_TIMEOUT_SEC=60
BLUEPRINT_GENERATE_TIMEOUT_SEC=60
BLUEPRINT_GENERATE_MAX_TOKENS=20480
